# 1. 베이스 이미지 선택
# openjdk 11 버전이 미리 설치된 가벼운 리눅스 이미지를 기반으로 시작합니다.
FROM openjdk:11-jdk-slim

# 2. 작업 디렉토리 설정
# 컨테이너 안에서 명령어를 실행할 기본 폴더를 /app 으로 지정합니다.
WORKDIR /app

# 3. 소스 코드 복사
# 내 컴퓨터(WSL)의 현재 폴더에 있는 모든 파일(.)을 컨테이너의 /app 폴더로 복사합니다.
COPY src /app/src

# 4. 자바 코드 컴파일
# 컨테이너 안에서 자바 컴파일러(javac)를 실행하여 Main.java 파일을 컴파일합니다.
# (프로젝트 구조에 맞게 파일 경로를 수정해야 할 수 있습니다. 예: src/Main.java)
RUN javac /app/src/Main.java

# 5. 컨테이너 시작 시 실행될 명령어 지정 (수정/제거 권장)
# CMD는 제거하거나, 기본 쉘(/bin/bash)을 실행하도록 변경할 수 있습니다.
# 여기서는 실행 시 'docker run' 명령으로 덮어쓸 것이므로, 그대로 두어도 큰 상관은 없지만,
# 명확성을 위해 이 줄을 제거하거나 아래와 같이 주석 처리하는 것을 권장합니다.
# CMD ["java", "-cp", "/app/src", "Main"]